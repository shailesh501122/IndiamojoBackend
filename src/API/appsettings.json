{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=indiamojo;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "IndiamojoBackend",
    "Audience": "IndiamojoClients",
    "Secret": "REPLACE_THIS_WITH_A_LONG_SECRET_FOR_PRODUCTION_USE_ONLY",
    "ExpiryMinutes": 60
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
